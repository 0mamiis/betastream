<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/suggestion_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="3dp"
    android:layout_marginBottom="3dp"
    android:background="@drawable/bg_popup_item"
    android:gravity="center_vertical"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="8dp"
    android:paddingBottom="10dp">

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@string/search_hint"
        android:src="@drawable/search_icon"
        app:tint="?attr/colorPrimary" />

    <TextView
        android:id="@+id/suggestion_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="?attr/textColor"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="Search suggestion" />

    <ImageView
        android:id="@+id/suggestion_fill"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_popup_field"
        android:contentDescription="@string/search_hint"
        android:padding="8dp"
        android:src="@drawable/ic_baseline_north_west_24"
        app:tint="?attr/textColor" />

</LinearLayout>

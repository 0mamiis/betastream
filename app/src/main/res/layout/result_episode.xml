<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/episode_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginBottom="12dp"
    android:foreground="@drawable/outline_drawable"
    android:minHeight="60dp"
    android:nextFocusRight="@id/download_button"
    app:cardBackgroundColor="@color/transparent"
    app:cardCornerRadius="@dimen/rounded_image_radius"
    app:cardElevation="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/episode_card_divider">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:id="@+id/watch_progress_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toTopOf="@id/episode_time_row"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/episode_play_icon"
                    style="@style/ContinueWatchingPlayUnderlayProgress"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:contentDescription="@null" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/episode_progress"
                    style="@style/ContinueWatchingCircularProgress"
                    android:layout_width="40dp"
                    android:layout_height="40dp" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/episode_filler"
                style="@style/SmallWhiteButton"
                android:layout_marginStart="10dp"
                android:minHeight="48dp"
                android:minWidth="48dp"
                android:padding="0dp"
                app:paddingStart="0dp"
                app:paddingEnd="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/filler"
                app:layout_constraintBottom_toTopOf="@id/episode_time_row"
                app:layout_constraintStart_toEndOf="@id/watch_progress_container"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/episode_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:marqueeRepeatLimit="0"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/episode_time_row"
                app:layout_constraintEnd_toStartOf="@id/download_button"
                app:layout_constraintStart_toEndOf="@id/episode_filler"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Episode 1" />

            <LinearLayout
                android:id="@+id/episode_time_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/download_button"
                app:layout_constraintStart_toStartOf="@id/episode_text"
                app:layout_constraintTop_toBottomOf="@id/episode_text">

                <TextView
                    android:id="@+id/episode_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="15 Apr 2024" />

                <ImageView
                    android:id="@+id/episode_time_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="9dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ic_baseline_access_time_24"
                    app:tint="?attr/grayTextColor"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/episode_runtime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/grayTextColor"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="28m" />

            </LinearLayout>

            <com.lagradost.cloudstream3.ui.download.button.PieFetchButton
                android:id="@+id/download_button"
                android:layout_width="53dp"
                android:layout_height="53dp"
                android:layout_marginEnd="8dp"
                android:background="?selectableItemBackgroundBorderless"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>

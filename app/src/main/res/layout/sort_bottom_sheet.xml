<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_sheet"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/PopupDialogTitle"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/pick_source" />

        <ListView
            android:id="@+id/sort_providers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:divider="@color/transparent"
            android:dividerHeight="0dp"
            android:maxHeight="240dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:requiresFadingEdge="vertical"
            tools:listitem="@layout/sort_bottom_single_choice" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sort_subtitles_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/PopupDialogTitle"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/pick_subtitle" />

        <ListView
            android:id="@+id/sort_subtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:divider="@color/transparent"
            android:dividerHeight="0dp"
            android:maxHeight="240dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:requiresFadingEdge="vertical"
            tools:listitem="@layout/sort_bottom_single_choice" />
    </LinearLayout>
</LinearLayout>
